# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (mặc định cho phát triển):
DATABASE_URL=sqlite:///./law_chatbot.db

# PostgreSQL (dành cho production hoặc nếu bạn đã cài Postgres):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/law_chatbot

# ─── Auth ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production

# ─── LLM: Chọn một trong hai ─────────────────────────────────────────────────
# Option A: Ollama local (recommended for development)
OLLAMA_URL=http://localhost:11434
LLM_MODEL=qwen2.5:7b

# Option B: OpenAI (bỏ comment nếu dùng OpenAI)
# OPENAI_API_KEY=sk-...
